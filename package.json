{
	"name": "@wadjet/monorepo",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@11.0.9",
	"engines": {
		"node": ">=24",
		"pnpm": ">=11"
	},
	"scripts": {
		"secrets": "secretlint '**/*'",
		"lint": "biome check",
		"format": "biome format --write",
		"format:check": "biome format",
		"compose:up": "docker compose up -d --wait",
		"compose:down": "docker compose down -v"
	},
	"lint-staged": {
		"*": "secretlint",
		"*.{ts,tsx,js,jsonc,md}": "biome check --write --no-errors-on-unmatched"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@secretlint/secretlint-rule-preset-recommend": "13.0.2",
		"secretlint": "13.0.2"
	}
}
