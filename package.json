{
	"name": "@thoth/monorepo",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@11.0.9",
	"engines": {
		"node": ">=24",
		"pnpm": ">=11"
	},
	"scripts": {
		"dev": "pnpm -r --parallel dev",
		"verify": "pnpm secrets && pnpm lint && pnpm typecheck && pnpm arch && pnpm peers check && pnpm spec-check && pnpm test && pnpm build",
		"secrets": "secretlint '**/*'",
		"lint": "biome check",
		"typecheck": "pnpm -r typecheck",
		"arch": "pnpm -r arch",
		"test": "pnpm -r test",
		"spec-check": "sdd-spec-check",
		"test:integration": "pnpm -r test:integration",
		"build": "pnpm -r build",
		"format": "biome format --write",
		"format:check": "biome format",
		"compose:up": "docker compose up -d --wait",
		"compose:watch": "docker compose watch",
		"compose:down": "docker compose down -v",
		"prepare": "husky"
	},
	"lint-staged": {
		"*": "secretlint",
		"*.{ts,tsx,js,jsonc,md}": "biome check --write --no-errors-on-unmatched",
		"*.{tf,tfvars}": "terraform fmt -write=true"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@commitlint/cli": "21.0.2",
		"@commitlint/config-conventional": "21.0.2",
		"@secretlint/secretlint-rule-preset-recommend": "13.0.2",
		"husky": "9.1.6",
		"lint-staged": "17.0.8",
		"sdd-spec-check": "0.1.1",
		"secretlint": "13.0.2"
	}
}
