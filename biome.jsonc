{
	"$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
	"files": {
		"includes": [
			"**",
			// excludes
			"!**/dist",
			"!**/node_modules",
			"!.ignored"
		]
	},
	"javascript": {
		"parser": {
			// Allow Inversify @inject() on constructor params
			"unsafeParameterDecoratorsEnabled": true
		}
	},
	"linter": {
		"rules": {
			"recommended": true
		}
	}
}
