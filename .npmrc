# versions
engine-strict=true             # wrong Node blocks install
package-manager-strict=true    # wrong pnpm blocks install
strict-peer-dependencies=true  # bad peer deps block install

# lockfile
save-exact=true                # no ^/~ ranges
prefer-frozen-lockfile=true    # CI fails on lockfile drift
verify-deps-before-run=true    # check node_modules matches lockfile

# supply chain
registry=https://registry.npmjs.org/  # explicit registry pin
minimum-release-age=10080             # block versions younger than 7 days

# hygiene
audit-level=high  # ignore low/moderate audit noise
fund=false        # silence funding footer
